{
  "name": "semant",
  "version": "1.0.0",
  "main": "dist/extension.cjs",
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . -outDir out",
    "watch-tests": "tsc -p . -outDir out -w",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "semant.search",
        "title": "Search",
        "category": "Semantic Search",
        "icon": "$(search)"
      },
      {
        "command": "semant.reindex",
        "title": "Reindex Workspace",
        "category": "Semantic Search",
        "icon": "$(refresh)"
      },
      {
        "command": "semant.clearIndex",
        "title": "Clear Index",
        "category": "Semantic Search",
        "icon": "$(trash)"
      }
    ],
    "keybindings": [
      {
        "command": "semant.search",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "semant.search",
          "group": "navigation",
          "when": "editorHasSelection"
        }
      ],
      "explorer/context": [
        {
          "command": "semant.reindex",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Semantic Search",
      "properties": {
        "semant.model": {
          "type": "string",
          "default": "Xenova/all-MiniLM-L6-v2",
          "description": "The HuggingFace model ID to use for embeddings."
        },
        "semant.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/.git/**"
          ],
          "description": "Glob patterns to exclude from indexing."
        }
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.3",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "ts-loader": "^9.5.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "onnxruntime-node": "^1.14.0",
    "webpack": "^5.105.2"
  }
}
